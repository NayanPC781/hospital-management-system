# Server Configuration
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://127.0.0.1:27017/hospital

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Frontend URL used in password reset links
CLIENT_URL=http://localhost:3000

# Optional SMTP settings for password reset emails.
# If these are missing in development, reset links are printed in the backend console.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Hospital Management <no-reply@example.com>"
